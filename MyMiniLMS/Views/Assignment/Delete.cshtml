@model MyMiniLMS.Models.Assignment

@{
    ViewData["Title"] = L["DeleteAssignment"];
}

<h1>@L["DeleteAssignment"]</h1>

<div class="alert alert-danger">
    @L["DeleteAssignmentConfirm"]
</div>

<dl class="row">
    <dt class="col-sm-2">@L["Title"]</dt>
    <dd class="col-sm-10">@Model.Title</dd>

    <dt class="col-sm-2">@L["Description"]</dt>
    <dd class="col-sm-10">@Model.Description</dd>

    <dt class="col-sm-2">@L["Deadline"]</dt>
    <dd class="col-sm-10">
        @(Model.Deadline.HasValue
            ? Model.Deadline.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
            : L["NoDeadline"])
    </dd>
</dl>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" name="id" value="@Model.Id" />

    <button type="submit" class="btn btn-danger">@L["Delete"]</button>

    <a asp-controller="Course"
       asp-action="Details"
       asp-route-id="@Model.CourseId"
       class="btn btn-secondary">
        @L["Back"]
    </a>
</form>
