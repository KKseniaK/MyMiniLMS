@using System.Globalization
@using Microsoft.AspNetCore.Identity
@using MyMiniLMS.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    var currentCulture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var nextCulture = currentCulture == "ru" ? "en" : "ru";
    var languageButtonText = currentCulture == "ru" ? "EN" : "RU";
    var returnUrl = Context.Request.PathBase + Context.Request.Path + Context.Request.QueryString;
}

<ul class="navbar-nav">
    <li class="nav-item">
        <form asp-area=""
              asp-controller="Localization"
              asp-action="SetLanguage"
              method="post"
              class="d-inline">
            <input type="hidden" name="culture" value="@nextCulture" />
            <input type="hidden" name="returnUrl" value="@returnUrl" />
            <button type="submit" class="nav-link btn btn-link text-dark">
                @languageButtonText
            </button>
        </form>
    </li>

    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <span class="nav-link text-dark">
                @User.Identity?.Name
            </span>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" method="post">
                <button type="submit" class="nav-link btn btn-link text-dark">
                    @L["Logout"]
                </button>
            </form>
        </li>
    }
    else
{
    <li class="nav-item">
        <a class="nav-link text-dark"
           asp-area=""
           asp-controller="Account"
           asp-action="Register">
            @L["Register"]
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">
            @L["Login"]
        </a>
    </li>
}
</ul>
