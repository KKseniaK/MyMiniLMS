@model MyMiniLMS.Models.Course

@{
    ViewData["Title"] = L["DeleteCourse"];
}

<h1>@L["DeleteCourse"]</h1>

<div class="alert alert-danger">
    @L["DeleteCourseConfirm"]
</div>

<dl class="row">
    <dt class="col-sm-2">@L["Name"]</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">@L["Description"]</dt>
    <dd class="col-sm-10">@Model.Description</dd>
</dl>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" name="id" value="@Model.Id" />

    <button type="submit" class="btn btn-danger">@L["Delete"]</button>
    <a asp-action="Index" class="btn btn-secondary">@L["Back"]</a>
</form>
