@model MyMiniLMS.Models.Course

@{
    ViewData["Title"] = L["EditCourse"];
}

<h1>@L["EditCourse"]</h1>

<form asp-action="Edit" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="CreatedAt" />

    <div class="mb-3">
        <label asp-for="Name" class="form-label">@L["CourseName"]</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label">@L["Description"]</label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">@L["SaveChanges"]</button>
    <a asp-action="Index" class="btn btn-secondary">@L["Back"]</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
